# Control plane host only — copy to /var/socks/gfc.env (or scripts/gfc.env)
GFC_ROOT=/var/socks

API_HOST=0.0.0.0
API_PORT=8080

WEB_HOST=0.0.0.0
WEB_PORT=5173

# 节点激活用 Bootstrap Token（转发节点 install.env 里 BOOTSTRAP_TOKEN 须与此一致）
GFC_BOOTSTRAP_TOKENS=demo-bootstrap
# 兼容旧变量名（start-all 会同步到 GFC_BOOTSTRAP_TOKENS）
BOOTSTRAP_TOKEN=demo-bootstrap
