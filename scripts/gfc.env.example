# Copy to /var/socks/gfc.env and customize
GFC_ROOT=/var/socks

API_HOST=0.0.0.0
API_PORT=8080

WEB_HOST=0.0.0.0
WEB_PORT=5173

# Node agent (same host: use 127.0.0.1; remote API: use public IP)
SERVER_URL=http://127.0.0.1:8080
BOOTSTRAP_TOKEN=demo-bootstrap
NODE_NAME=MY-Node-01
REGION=ap-southeast-1
POLL_SECONDS=10

STATE_FILE=/var/socks/node-agent/state/node_state.json
CONFIG_DIR=/var/socks/node-agent/state/dataplane

# Forward node only (install-ubuntu.sh): ingress interface for TPROXY
# GFC_TPROXY_IFACE=eth1
