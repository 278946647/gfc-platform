# 转发节点安装参数（复制为 install.env 后修改，或 install.sh --config install.env）
# 安装完成后会同步写入 /etc/gfc-node/gfc.env 与 /etc/gfc-node/install.env

# 控制平台地址（二选一：完整 URL 或 IP+端口）
SERVER_URL=http://103.78.41.15:8080
# CONTROL_PLANE_IP=103.78.41.15
# API_PORT=8080

# 须与控制平台 API 的 GFC_BOOTSTRAP_TOKENS 一致（默认 demo-bootstrap，见下方说明）
BOOTSTRAP_TOKEN=demo-bootstrap
# 在控制平台主机查看:
#   grep -r GFC_BOOTSTRAP /var/socks/gfc.env /var/socks/scripts/gfc.env 2>/dev/null
#   ps eww -p $(cat /var/socks/run/gfc-api.pid) 2>/dev/null | tr ' ' '\n' | grep GFC_BOOTSTRAP
# 未配置时 API 默认值为 demo-bootstrap

# 控制台「转发节点」中显示的名称（可之后在 Web UI 改名）
NODE_NAME=MY-Node-01
REGION=ap-southeast-1

# 以太网直通模式：VyOS/客户流量「入向」网卡（安装脚本会列出本机网卡，按实际名称填写）
# 不同云平台名称不同（ens160、eth0、ens3…），不要照搬示例，以 ip -br link 为准
# GFC_TPROXY_IFACE=

# 切到 OpenVPN 后，控制台会下发 tproxyIface（通常 tun0），优先于本项，一般无需改这里

# DNS：全程国际 DoH（默认 1.1.1.1）；SOCKS 故障时改走转发节点本机公网直连（不经 SOCKS）
# GFC_DNS_FALLBACK=1
# GFC_DNS_INTL_SERVER=1.1.1.1
# GFC_SOCKS_DNS_PROBE_SECONDS=30
# GFC_SOCKS_DNS_FAIL_THRESHOLD=2

# 默认出口 SNAT：auto = 自动读取「默认路由」网卡（随云平台变化，无需写死名称）
GFC_SNAT_IFACE=auto
# 手工指定出口网卡时才填具体名称；关闭 SNAT: GFC_SNAT_IFACE=off

# 可选
# GFC_ROOT=/opt/gfc-node
# REPO_SRC=/var/socks
# SINGBOX_VERSION=1.13.4
# POLL_SECONDS=10
