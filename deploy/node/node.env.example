# 兼容旧流程：setup-after-copy.sh 仍可读此文件。
# 新部署请优先使用 install.env.example + install.sh

SERVER_URL=http://<control-plane-ip>:8080
BOOTSTRAP_TOKEN=demo-bootstrap
NODE_NAME=MY-Node-01
REGION=ap-southeast-1

# 以太网模式：客户/VyOS 流量入向网卡（名称因云平台而异，安装时 ip -br link 查看）
# GFC_TPROXY_IFACE=
# GFC_SNAT_IFACE=auto

# 可选
# GFC_ROOT=/opt/gfc-node
# REPO_SRC=/var/socks
