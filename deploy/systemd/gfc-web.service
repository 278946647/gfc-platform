[Unit]
Description=GFC Web UI (Vite dev server)
After=network-online.target gfc-api.service
Wants=gfc-api.service

[Service]
Type=simple
User=root
WorkingDirectory=/var/socks/web-ui
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0 --port 5173
Restart=always
RestartSec=3
StandardOutput=append:/var/socks/logs/gfc-web.log
StandardError=append:/var/socks/logs/gfc-web.log

[Install]
WantedBy=multi-user.target
