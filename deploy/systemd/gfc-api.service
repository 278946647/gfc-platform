[Unit]
Description=GFC Control Plane API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/socks/control-plane/api
Environment=PATH=/var/socks/control-plane/api/.venv/bin
ExecStart=/var/socks/control-plane/api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3
StandardOutput=append:/var/socks/logs/gfc-api.log
StandardError=append:/var/socks/logs/gfc-api.log

[Install]
WantedBy=multi-user.target
